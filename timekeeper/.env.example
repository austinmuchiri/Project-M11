# Supabase — fill these in (or leave blank to run in mock mode)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Same vars for Electron (no VITE_ prefix needed but kept for symmetry)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Demo flag — when "true", apps use seeded in-memory data instead of Supabase
TIMEKEEPER_DEMO=true
