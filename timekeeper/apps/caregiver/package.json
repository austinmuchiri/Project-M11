{
  "name": "@timekeeper/caregiver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "typecheck": "tsc -b --noEmit",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "build:android": "pnpm build && cap sync android && cd android && gradlew.bat assembleDebug || ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "6.2.0",
    "@capacitor/app": "6.0.2",
    "@capacitor/core": "6.2.0",
    "@capacitor/preferences": "6.0.3",
    "@capacitor/push-notifications": "6.0.3",
    "@capacitor/share": "6.0.3",
    "@timekeeper/schema": "workspace:*",
    "@timekeeper/supabase-client": "workspace:*",
    "@timekeeper/ui": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "6.2.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "typescript": "5.6.3",
    "vite": "5.4.10"
  }
}
