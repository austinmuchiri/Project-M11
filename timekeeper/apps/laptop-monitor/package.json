{
  "name": "@timekeeper/laptop-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Electron tray app: full OS-level foreground-app monitor + lockscreen",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node build.cjs && electron .",
    "build": "node build.cjs",
    "typecheck": "tsc -p . --noEmit",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:linux": "pnpm build && electron-builder --linux"
  },
  "dependencies": {
    "@timekeeper/schema": "workspace:*",
    "@timekeeper/supabase-client": "workspace:*",
    "active-win": "8.2.1",
    "dotenv": "^17.4.2",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "@types/node": "20.16.13",
    "electron": "33.0.2",
    "electron-builder": "25.1.8",
    "esbuild": "0.24.0",
    "typescript": "5.6.3"
  },
  "author": "Hackcessible 2026 Group 1",
  "build": {
    "appId": "com.timekeeper.monitor",
    "productName": "TimeKeeper Monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "electronDist": "../../node_modules/.pnpm/electron@33.0.2/node_modules/electron/dist",
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
